{
  "manifest_version": 3,
  "name": "Lilith Auto Draw",
  "version": "1.0",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "webRequest",
    "webRequestAuthProvider",
    "alarms"
  ],
  "host_permissions": [
    "https://*.lilithgame.com/*",
    "https://store.lilith.com/*",
    "https://*.plutomall.com/*",
    "https://*.plutomall.com.vn/*",
    "https://campaign-global.lilith.com/*",
    "https://plat-campaign-api.lilithgame.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icons/icon16.png",
    "32": "images/icons/icon32.png",
    "48": "images/icons/icon48.png",
    "128": "images/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icons/icon16.png",
      "32": "images/icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://plat-campaign-api.lilithgame.com/*",
        "https://campaign-global.lilith.com/*",
        "https://www.plutomall.com.vn/*",
        "https://*.lilithgame.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://plat-campaign-api.lilithgame.com/*",
        "https://campaign-global.lilith.com/*",
        "https://www.plutomall.com.vn/*",
        "https://*.lilithgame.com/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ]
}